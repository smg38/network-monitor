# nm-config.env - ЧИСТЫЙ environment файл для systemd (Версия 1.6)
# Используется: EnvironmentFile= в nm-daemon.service
# НЕ содержит bash-кода! Только простые переменные (export)
# Правила мониторинга перенесены в БД (nm-config-rules.sql)

## ГРУППА 1: СЕТЕВЫЕ ИНТЕРФЕЙСЫ
MAIN_IFACE=ens3                    # Основной интерфейс для мониторинга
WG_IFACE=wg0                       # WireGuard интерфейс (пусто = отключено)

## ГРУППА 2: ПУТИ К ФАЙЛАМ
BASE_DIR=/opt/network-monitor      # Основная директория проекта
DB_PATH=${BASE_DIR}/nm-data.db     # Путь к SQLite базе данных
CONFIG_PATH=${BASE_DIR}/nm-config.env  # Путь к этому файлу
LOG_DIR=/var/log/network-monitor   # Директория логов
LOG_FILE=${LOG_DIR}/nm-daemon.log  # Основной лог-файл демона

## ГРУППА 3: НАСТРОЙКИ ЛОГИРОВАНИЯ
LOG_LEVEL=INFO                     # DEBUG|INFO|WARN|ERROR
LOG_MAX_SIZE=100                   # Максимальный размер лога (MB)
LOG_MAX_FILES=5                    # Количество файлов ротации

## ГРУППА 4: ТАЙМЕРЫ И ЛИМИТЫ
CHECK_INTERVAL=60                  # Интервал проверки задач демона 10(сек)
LIVE_REFRESH_INTERVAL=60           # Интервал обновления в live-режиме 2(сек)
TOP_PEERS_DEFAULT=10               # Количество топ-клиентов по умолчанию

# ========================================
# ПРАВИЛА ПЕРЕНЕСЕНЫ В БД (config_rules):
# - collect: 5s, 60s 
# - aggregate: 5min, 1h, 1day из raw/агрегатов  
# - cleanup: raw=7d, agg_5min=30d, agg_hour=90d, agg_day=365d
# ========================================
# Управление: sqlite3 DB_PATH "UPDATE config_rules SET enabled=1 WHERE rule_key='5'" 
# Список:    sqlite3 DB_PATH "SELECT * FROM config_rules WHERE enabled=1"

